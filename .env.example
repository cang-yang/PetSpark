# These values are for local development only. Copy to .env.local and match your existing MySQL.
# .env.local is gitignored — never commit real credentials.
MYSQL_DATABASE=petspark
MYSQL_HOST=localhost
MYSQL_PORT=3306

DB_URL=jdbc:mysql://localhost:3306/petspark?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# Browser-direct backend access is disabled by default. When explicitly needed, list exact origins.
PETSPARK_CORS_ALLOWED_ORIGINS=

# Optional demo accounts are disabled by default. Never commit real passwords.
PETSPARK_DEMO_USERS_ENABLED=false
PETSPARK_DEMO_ADMIN_PASSWORD=
PETSPARK_DEMO_MEMBER_PASSWORD=

# AI remains disabled unless .env.spark.local is present or deployment explicitly enables it.
# For local Spark usage, create the gitignored .env.spark.local with SPARK_API_PASSWORD,
# SPARK_BASE_URL and SPARK_MODEL. The local loader derives SPARK_ENABLED=true from a non-empty password.
SPARK_ENABLED=false
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v2
SPARK_MODEL=spark-x
# Put real Spark APIPassword only in .env.spark.local or deployment environment variables.
SPARK_API_PASSWORD=
