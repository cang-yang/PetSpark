# These values are for local development only. Copy to .env and match your existing MySQL.
MYSQL_DATABASE=petspark
MYSQL_PORT=3306

DB_URL=jdbc:mysql://localhost:3306/petspark?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# AI remains disabled in the base scaffold. Never put a real key in this file.
SPARK_ENABLED=false
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v2
SPARK_MODEL=spark-x
