# Copy to /opt/petspark/.env, replace every CHANGE_ME value, then chmod 600.
IMAGE_TAG=latest
WEB_BIND_PORT=18081

MYSQL_DATABASE=petspark
MYSQL_USER=petspark
MYSQL_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
AI_MESSAGE_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
PETSPARK_HEALTH_DETAIL_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
PETSPARK_USER_PHONE_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES

PETSPARK_DEMO_USERS_ENABLED=true
PETSPARK_DEMO_ADMIN_USERNAME=admin
PETSPARK_DEMO_ADMIN_EMAIL=admin@petspark.local
PETSPARK_DEMO_ADMIN_NICKNAME=平台管理员
PETSPARK_DEMO_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PETSPARK_DEMO_MEMBER_USERNAME=demo
PETSPARK_DEMO_MEMBER_EMAIL=demo@petspark.local
PETSPARK_DEMO_MEMBER_NICKNAME=演示用户
PETSPARK_DEMO_MEMBER_PASSWORD=CHANGE_ME_MEMBER_PASSWORD
PETSPARK_DEMO_DATA_ENABLED=true
PETSPARK_DEMO_DATA_FUTURE_DAYS=7

MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SSL_ENABLED=true
MAIL_STARTTLS_ENABLED=false
MAIL_CONNECTION_TIMEOUT_MS=5000
MAIL_READ_TIMEOUT_MS=5000
MAIL_WRITE_TIMEOUT_MS=5000
REGISTRATION_MAIL_ENABLED=false
REGISTRATION_MAIL_FROM=
PASSWORD_RESET_MAIL_ENABLED=false
PASSWORD_RESET_MAIL_FROM=

SPARK_ENABLED=false
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v2
SPARK_MODEL=spark-x
SPARK_API_PASSWORD=
AI_CARE_QA_ENABLED=false
