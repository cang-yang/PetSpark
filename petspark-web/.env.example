# Vue CLI local development uses same-origin `/api` requests through vue.config.js.
# Keep the base URL empty; setting it to http://localhost:8080 bypasses the proxy and triggers CORS.
VUE_APP_API_BASE_URL=

# Override only when the local backend listens somewhere other than http://localhost:8080.
PETSPARK_DEV_API_TARGET=http://localhost:8080
